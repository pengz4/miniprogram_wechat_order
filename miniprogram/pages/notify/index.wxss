.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f7f8fa;
}

.card,
.error-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
}

.title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.subtitle,
.tip {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.block {
  margin-top: 18rpx;
}

.error-card {
  color: #b91c1c;
  background: #fee2e2;
}

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #edf0f3;
}

.status-row:last-of-type {
  border-bottom: none;
}

.label {
  font-size: 28rpx;
  color: #111827;
}

.value {
  font-size: 26rpx;
}

.ok {
  color: #047857;
}

.warn,
.warn-text {
  color: #b45309;
}

.primary-btn,
.secondary-btn {
  margin-top: 12rpx;
  border-radius: 40rpx;
}

.primary-btn {
  color: #ffffff;
  background: #07c160;
}

.secondary-btn {
  color: #111827;
  background: #f3f4f6;
}

.primary-btn::after,
.secondary-btn::after {
  border: none;
}
