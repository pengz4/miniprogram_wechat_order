.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f7f8fa;
}

.header-card,
.error-card,
.empty-card,
.order-card {
  margin-bottom: 24rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
}

.title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.subtitle,
.empty-tip,
.created-at {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.error-card {
  color: #b91c1c;
  background: #fee2e2;
}

.notify-btn {
  margin: 0;
  min-width: 156rpx;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #111827;
  background: #f3f4f6;
  border-radius: 999rpx;
}

.notify-btn::after {
  border: none;
}

.empty-card {
  text-align: center;
}

.empty-title {
  display: block;
  font-size: 30rpx;
  color: #111827;
}

.order-header,
.order-item,
.order-footer {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.order-header {
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.nickname {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.status {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #047857;
  background: #d1fae5;
}

.order-item {
  padding: 14rpx 0;
  font-size: 28rpx;
  color: #374151;
  border-bottom: 1rpx solid #edf0f3;
}

.order-item:last-of-type {
  border-bottom: none;
}

.order-footer {
  align-items: flex-end;
  margin-top: 20rpx;
  padding-top: 20rpx;
  font-size: 24rpx;
  color: #6b7280;
  border-top: 1rpx solid #edf0f3;
}

.footer-meta {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.notify-text {
  color: #6b7280;
}

.total {
  color: #111827;
  font-weight: 600;
}
