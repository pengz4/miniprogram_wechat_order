.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 180rpx;
  box-sizing: border-box;
  background: #f7f8fa;
}

.layout {
  display: flex;
  min-height: 860rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
}

.category-list {
  width: 190rpx;
  background: #f1f3f5;
}

.category-item {
  padding: 32rpx 20rpx;
  font-size: 28rpx;
  color: #4b5563;
  border-left: 6rpx solid transparent;
}

.category-item.active {
  color: #111827;
  font-weight: 600;
  background: #ffffff;
  border-left-color: #07c160;
}

.dish-list {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

.dish-card {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #edf0f3;
}

.dish-card:last-child {
  border-bottom: none;
}

.dish-meta {
  flex: 1;
}

.dish-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.dish-desc {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6b7280;
}

.dish-price {
  display: block;
  margin-top: 14rpx;
  font-size: 30rpx;
  color: #ef4444;
  font-weight: 600;
}

.dish-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.qty-btn {
  width: 60rpx;
  min-width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0;
  border-radius: 50%;
  font-size: 34rpx;
  color: #374151;
  background: #f3f4f6;
}

.qty-btn::after {
  border: none;
}

.add-btn {
  color: #ffffff;
  background: #07c160;
}

.qty-text {
  min-width: 28rpx;
  text-align: center;
  font-size: 28rpx;
  color: #111827;
}

.footer-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(17, 24, 39, 0.94);
  color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 18rpx 40rpx rgba(17, 24, 39, 0.18);
}

.cart-summary {
  flex: 1;
}

.cart-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.cart-tip {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.72);
}

.footer-actions {
  display: flex;
  gap: 16rpx;
}

.secondary-btn,
.primary-btn {
  min-width: 156rpx;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 24rpx;
  border-radius: 38rpx;
  font-size: 28rpx;
}

.secondary-btn {
  color: #ffffff;
  background: rgba(255, 255, 255, 0.12);
}

.primary-btn {
  color: #ffffff;
  background: #07c160;
}

.secondary-btn::after,
.primary-btn::after {
  border: none;
}
