.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  background: #f7f8fa;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
}

.section-title {
  margin-bottom: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.cart-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #edf0f3;
}

.cart-item:last-of-type {
  border-bottom: none;
}

.item-name {
  display: block;
  font-size: 30rpx;
  color: #111827;
}

.item-price {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.item-subtotal {
  font-size: 30rpx;
  font-weight: 600;
  color: #ef4444;
}

.summary-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #edf0f3;
  font-size: 28rpx;
  color: #374151;
}

.summary-price {
  color: #111827;
  font-weight: 600;
}

.picker-group {
  display: grid;
  gap: 20rpx;
}

.picker-field {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 20rpx;
  border-radius: 18rpx;
  background: #f3f4f6;
}

.picker-label {
  font-size: 28rpx;
  color: #374151;
}

.picker-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.picker-tip {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.remark-input {
  width: 100%;
  min-height: 180rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  background: #f3f4f6;
  font-size: 28rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 420rpx;
  padding: 24rpx;
  color: #6b7280;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.empty-tip {
  margin-top: 12rpx;
  font-size: 26rpx;
}

.submit-btn {
  margin-top: 48rpx;
  border-radius: 44rpx;
  color: #ffffff;
  background: #07c160;
}

.submit-btn[disabled] {
  color: rgba(255, 255, 255, 0.75);
  background: #9ca3af;
}

.submit-btn::after {
  border: none;
}
